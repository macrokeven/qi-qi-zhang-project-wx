/* pages/home/home.wxss */
.search-icon {
    position: absolute;
    margin-left: 60rpx;
    width: 60rpx;
    height: 60rpx;
}


.search-box {
    margin-left: 40rpx;
    border-radius: 32rpx;
    /*width: calc(85% - 218rpx);*/
    width: calc(100% - 208rpx);
    border: 2rpx solid #e0e0e0;
    height: 108rpx;
    font-size: 30rpx;
    padding: 0 0 0 100rpx;
    font-family: "Microsoft YaHei UI";
    font-weight: 500;
    line-height: 22px;
    letter-spacing: 0;
    text-align: left;
}

.alert {
    margin: 0 30rpx 0 30rpx;
    width: 108rpx;
    height: 108rpx;
}

.title-label {
    margin: 0 0 0 40rpx;
    color: rgb(31, 34, 38);
    font-family: Barlow;
    font-size: 36rpx;
    font-weight: 700;
    line-height: 52rpx;
    letter-spacing: 0;
    padding: 0;
}

.l-btn {
    width: 120rpx;
    height: 52rpx;
    background: rgb(41, 105, 255);
    border-radius: 12rpx;
    color: white;
    text-align: center;
    line-height: 52rpx;
    margin: 0 20rpx 0 auto;
}

.scroll-h {
    margin-top: 40rpx;
    display: flex;
    overflow-y: scroll;
    max-width: 100vw;
    min-width: 100vw;
}

.card {
    margin: 0 20rpx;
    width: 600rpx;
    height: 286rpx;
    border-radius: 32rpx;
    position: relative;
}

.card-logo {
    position: absolute;
    width: 96rpx;
    height: 96rpx;
    border-radius: 8px;
    margin: 32rpx;
}

.tax-name {
    color: rgb(255, 255, 255);
    font-size: 32rpx;
    font-weight: 500;
    letter-spacing: 0;
    text-align: left;
    margin: 4rpx 0;
    width: fit-content;
}

.card-s-logo {
    width: 36rpx;
    height: 36rpx;
    margin-left: 32rpx;
}

.tax-date {
    color: rgba(255, 255, 255, 0.5);
    font-size: 24rpx;
    font-weight: 500;
    letter-spacing: 0;
    text-align: left;
    margin: 4rpx 0;
    width: fit-content;

}

.tax-status {
    color: rgba(255, 255, 255, 0.5);
    font-size: 40rpx;
    font-weight: 500;
    letter-spacing: 0;
    text-align: left;
    margin: 43rpx 40rpx 0 auto;
    width: fit-content;
    color: rgb(52, 168, 83);

}

.card-like {
    margin: 32rpx 32rpx 0 508rpx;
    position: absolute;
    width: 52rpx;
    height: 52rpx;
    border-radius: 9rpx;
}

.card-n {
    width: 90%;
    height: 150rpx;
    background: #F6F8FA;
    border-radius: 32rpx;
    display: flex;
    flex-direction: row;
    margin: 20rpx 0;
}

.card-n-logo {
    width: 96rpx;
    height: 96rpx;
    border-radius: 8px;
    margin: 27rpx 0 27rpx 27rpx;
}

.b-blue {
    background: rgb(41, 105, 255);
}

.t-blue {
    color: rgb(41, 105, 255);
}

.b-black {
    background: #1F2226;
}

.b-red {
    background: #EB4335;
}

.b-purple {
    background: #5F29FF;
}

.t-black {
    color: #1F2226;
}

.t-grey {
    color: rgba(31, 34, 38, 0.5);
}

.tab-box {
    width: 100%;
    height: 120rpx;
    padding-bottom: constant(safe-area-inset-bottom);
    padding-bottom: env(safe-area-inset-bottom);
}