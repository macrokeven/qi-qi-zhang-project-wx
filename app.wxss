/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
.l-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.l-row {
  display: flex;
  flex-direction: row;
  width: 100%;
}
